{
  "$schema": "https://turbo.build/schema.json",
  "extends": [
    "//"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "build:cjs",
        "build:package-json",
        "build:esm"
      ]
    },
    "storybook": {
      "dependsOn": [
        "//#install:modules"
      ]
    },
    "build:storybook": {
      "dependsOn": [
        "//#install:modules"
      ],
      "outputs": [
        "storybook-static/**"
      ]
    },
    "fix:lint": {
      "dependsOn": [
        "fix:lint:eslint",
        "fix:lint:stylelint"
      ],
      "cache": false
    },
    "fix:lint:eslint": {
      "dependsOn": [
        "//#install:modules",
        "^build"
      ],
      "cache": false
    },
    "fix:lint:stylelint": {
      "dependsOn": [
        "//#install:modules"
      ],
      "cache": false
    },
    "start:dev": {
      "with": [
        "start:dev:tsc"
      ],
      "persistent": false
    },
    "start:dev:sass": {
      "dependsOn": [
        "//#install:modules"
      ],
      "persistent": true,
      "cache": false
    },
    "start:dev:tsc": {
      "dependsOn": [
        "//#install:modules",
        "^build"
      ],
      "persistent": true,
      "cache": false
    },
    "test:lint": {
      "dependsOn": [
        "//#install:modules",
        "^build",
        "test:lint:eslint",
        "test:lint:stylelint"
      ]
    },
    "test:lint:eslint": {
      "dependsOn": [
        "//#install:modules",
        "^build"
      ]
    },
    "test:lint:stylelint": {
      "dependsOn": [
        "//#install:modules"
      ]
    }
  }
}