{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "build:cjs",
        "build:css:cjs",
        "build:css:esm",
        "build:package-json",
        "build:theme.scss",
        "build:esm"
      ]
    },
    "build:css:cjs": {
      "dependsOn": ["//#install:modules"],
      "inputs": ["src/**/*.scss"],
      "outputs": ["dist/cjs/**/*.css"]
    },
    "build:css:esm": {
      "dependsOn": ["//#install:modules"],
      "inputs": ["src/**/*.scss"],
      "outputs": ["dist/esm/**/*.css"]
    },
    "build:storybook": {
      "dependsOn": ["//#install:modules"],
      "outputs": ["storybook-static/**"]
    },
    "build:theme.scss": {
      "dependsOn": ["//#install:modules"],
      "inputs": ["src/theme.scss"],
      "outputs": ["dist/theme.scss"]
    },
    "start:dev": {
      "persistent": false,
      "with": ["start:dev:sass", "start:dev:theme.scss", "start:dev:tsc"]
    },
    "start:dev:sass": {
      "cache": false,
      "dependsOn": ["//#install:modules"],
      "persistent": true
    },
    "start:dev:theme.scss": {
      "cache": false,
      "dependsOn": ["//#install:modules", "^build"],
      "persistent": true
    },
    "start:dev:tsc": {
      "cache": false,
      "dependsOn": ["//#install:modules", "^build"],
      "persistent": true
    },
    "storybook": {
      "dependsOn": ["//#install:modules"]
    }
  }
}
